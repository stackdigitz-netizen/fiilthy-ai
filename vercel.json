{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "{ceo/frontend/**,ceo/store-backend/**,ceo/backend/tests/**,ceo/backend/scripts/**,ceo/backend/logs/**,tests/**,test_reports/**,exports/**,memory/**,**/__pycache__/**,**/*.pyc,*.md,*.txt,DEPLOY*.py,LAUNCH*.py}"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
